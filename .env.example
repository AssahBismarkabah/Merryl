# Merryl local environment template.
# Copy this file to `.env`, fill the real values, then load it before running the CLI.

# Required: Alpaca API Key ID and Secret Key.
# Use the standard API Key ID + Secret Key pair, not client_secret/private_key_jwt credentials.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Required for Phase 5 macro/regime context ingestion.
# Create a free key from the official FRED API key page.
FRED_API_KEY=

# Required for Phase 5C structured earnings calendar context.
# Create a free key from the official Alpha Vantage support/API key page.
ALPHA_VANTAGE_API_KEY=

# Optional: market data feed.
# Keep `iex` first unless the account has access to another feed such as `sip`.
ALPACA_FEED=iex

# Optional: Alpaca market data base URL.
ALPACA_DATA_URL=https://data.alpaca.markets

# Optional: FRED macro data base URL.
FRED_API_URL=https://api.stlouisfed.org

# Optional: Alpha Vantage base URL and earnings calendar horizon.
ALPHA_VANTAGE_API_URL=https://www.alphavantage.co
MERRYL_EARNINGS_CALENDAR_HORIZON=3month

# Optional: recent SEC filing lookback.
MERRYL_SEC_FILINGS_LOOKBACK_DAYS=14

# Required for Phase 5C SEC filing context.
# Use a SEC-compliant user agent with contact information.
MERRYL_SEC_USER_AGENT=Merryl/0.1 your-email@example.com

# Optional: calendar-day lookback used to fetch enough daily bars for rotation scoring.
MERRYL_LOOKBACK_DAYS=420

# Optional: calendar-day macro lookback used for FRED series ingestion.
MERRYL_MACRO_LOOKBACK_DAYS=900

# Optional: Phase 6A signal-only intraday readiness controls.
MERRYL_ALPACA_REQUESTS_PER_MINUTE=180
MERRYL_INTRADAY_PROFILE_TIMEFRAME=30Min
MERRYL_INTRADAY_TRIGGER_TIMEFRAME=5Min
MERRYL_INTRADAY_CANDIDATE_LIMIT=50
MERRYL_INTRADAY_OPENING_RANGE_MINUTES=30
